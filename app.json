{
  "expo": {
    "name": "RupyaSetu",
    "slug": "rupyasetu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rupyasetu",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8E8E8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rupyasetu"
    },
    "android": {
      "package": "com.rupyasetu",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#E8E8E8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "RupyaSetu needs your location for AEPS merchant KYC verification.",
          "locationWhenInUsePermission": "RupyaSetu needs your location for AEPS merchant KYC verification."
        }
      ],
      "./plugins/withNetworkSecurityConfig"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {}
    }
  }
}
